{
  "name": "cicd-jenkins-project",
  "version": "1.0.0",
  "description": "Proyecto completo de CI/CD para la materia Gestión de la Configuración del Software",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --ci --reporters=default --reporters=jest-junit"
  },
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "jest-junit": {
    "outputDirectory": "./",
    "outputName": "junit.xml",
    "usePathForSuiteName": "true"
  },
  "private": true
}
